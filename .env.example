# ============================================================
# ENVIRONMENT VARIABLES — Sistem Informasi Agenda Kegiatan
# ============================================================
# Salin file ini ke .env (untuk development lokal)
# Isi nilai yang sebenarnya — JANGAN commit .env ke GitHub!
# ============================================================

# ──────────────────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# Ambil dari: https://console.neon.tech → Connection string
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ──────────────────────────────────────────────────────────
# AUTHENTICATION (NextAuth v5)
# AUTH_SECRET: Buat dengan perintah: openssl rand -base64 32
# AUTH_URL: URL lengkap tempat backend berjalan
# ──────────────────────────────────────────────────────────
AUTH_SECRET="isi-dengan-string-random-panjang-minimal-32-karakter"
AUTH_URL="http://localhost:3000"

# Backward compatibility
NEXTAUTH_SECRET="isi-dengan-string-random-panjang-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────
# SPLIT DEPLOYMENT CONFIG
# NEXT_PUBLIC_API_URL: URL backend Vercel (untuk Cloudflare Pages)
# FRONTEND_URL: URL frontend Cloudflare Pages (untuk CORS di backend)
# ──────────────────────────────────────────────────────────

# === UNTUK DEVELOPMENT LOKAL (monolith di satu port) ===
NEXT_PUBLIC_API_URL=""
FRONTEND_URL=""

# === UNTUK DEPLOYMENT VERCEL (backend) ===
# NEXT_PUBLIC_API_URL=""          # Kosongkan — backend tidak perlu ini
# FRONTEND_URL="https://jadwalkegiatan.pages.dev"  # URL Cloudflare Pages Anda

# === UNTUK DEPLOYMENT CLOUDFLARE PAGES (frontend) ===
# NEXT_PUBLIC_API_URL="https://nama-proyek.vercel.app"  # URL Vercel Anda
# FRONTEND_URL=""                 # Tidak diperlukan di frontend
