# ============================================================
# Sistem Informasi Daftar Kegiatan Kantor
# Environment Variables
# Salin file ini ke .env dan isi sesuai konfigurasi Anda
# ============================================================

# ------------------------------------------------------------
# DATABASE — Neon.tech PostgreSQL
# Dapatkan dari: https://console.neon.tech/
# ------------------------------------------------------------

# Connection pooling URL (untuk runtime — PrismaClient)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct URL (untuk Prisma Migrate, tanpa pooling)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------
# NEXTAUTH — Autentikasi
# Generate secret: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_SECRET="ganti-dengan-string-random-minimal-32-karakter-XXX"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# (Opsional) PostgreSQL lokal untuk Docker Compose
# ------------------------------------------------------------
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres123
# POSTGRES_DB=kegiatan_kantor
