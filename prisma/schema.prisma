// Prisma Schema — Prisma 7.x (driverAdapters tidak lagi butuh previewFeatures)

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ATASAN
}

enum ActionType {
  CREATE_ACTIVITY
  UPDATE_ACTIVITY
  DELETE_ACTIVITY
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      String   @default("PIMPINAN")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities    Activity[]
  activityLogs  ActivityLog[]
  
  parent        User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children      User[]   @relation("UserHierarchy")

  @@map("users")
}

model Activity {
  id              String    @id @default(cuid())
  title           String
  activityDate    DateTime  @map("activity_date")
  location        String
  transitLocation String?   @map("transit_location")
  dresscode       String
  invitationTime  String    @map("invitation_time")
  description     String?
  customFields    String?   @map("custom_fields") // Menyimpan data JSON dari kolom-kolom custom
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creator      User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]

  @@index([activityDate])
  @@index([createdBy])
  @@map("activities")
}

model ActivityLog {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  activityId String     @map("activity_id")
  action     String
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model FieldConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  type      String   // "standard" or "custom"
  inputType String   // "text", "date", "time", "textarea" dsb
  order     Int      
  isActive  Boolean  @default(true)

  @@map("field_configs")
}
